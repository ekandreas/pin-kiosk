<!doctype html>
<html lang="sv">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>Flipperklubben Kiosk</title>
<style>
  :root { color-scheme: dark; }
  * { box-sizing: border-box; }
  html, body {
    height: 100%;
    margin: 0;
    font-family: system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
    background: radial-gradient(1200px 800px at 50% 30%, #1a1a2e 0%, #0b0b12 70%);
    color: #f5f5fa;
    cursor: none;
  }
  .wrap {
    height: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    text-align: center;
    padding: 6vmin;
    gap: 2.4vmin;
  }
  .logo { max-width: 38vmin; max-height: 28vmin; object-fit: contain; }
  h1 { font-size: 6vmin; margin: 0; font-weight: 700; letter-spacing: .5px; }
  h2 { font-size: 3.4vmin; margin: 0; font-weight: 500; color: #c7c7e0; }
  .message { font-size: 2.6vmin; margin: 0; color: #9a9ac0; }
  .detail { font-size: 2vmin; margin: 0; color: #6b6b8a; }
  .dot {
    width: 1.4vmin; height: 1.4vmin; border-radius: 50%;
    background: #4ade80; box-shadow: 0 0 2vmin #4ade80;
    animation: pulse 2s ease-in-out infinite;
  }
  @keyframes pulse { 0%,100% { opacity: .35; } 50% { opacity: 1; } }
</style>
</head>
<body>
  <div class="wrap">
    {{LOGO}}
    <h1>{{HEADING}}</h1>
    <h2>{{SUBHEADING}}</h2>
    <p class="message">{{MESSAGE}}</p>
    <p class="detail">{{DETAIL}}</p>
    <div class="dot"></div>
  </div>
</body>
</html>
