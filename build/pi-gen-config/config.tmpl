# pi-gen-konfiguration för Flipperklubben Kiosk.
# Genereras per modell av build/build.sh (platshållare ersätts).

IMG_NAME="__IMG_NAME__"
PI_GEN_RELEASE="Flipperklubben Kiosk"
# trixie = nuvarande Raspberry Pi OS / Debian stable (2025–). pi-gens arm64-
# branch riktar sig mot trixie; bygg därför trixie för att slippa mismatchar.
RELEASE="trixie"

# Bootar till konsol; vår systemd-tjänst startar X/Chromium.
TARGET_HOSTNAME="kiosk"

# Standardanvändare för underhåll (SSH). BYT LÖSENORD på osäkra platser!
FIRST_USER_NAME="flipperklubben"
FIRST_USER_PASS="__FIRST_USER_PASS__"
DISABLE_FIRST_BOOT_USER_RENAME="1"
ENABLE_SSH="1"

# Svensk lokal/tangentbord/tidszon.
LOCALE_DEFAULT="sv_SE.UTF-8"
KEYBOARD_KEYMAP="se"
KEYBOARD_LAYOUT="Swedish"
TIMEZONE_DEFAULT="Europe/Stockholm"

# Bygg endast: Lite-bas (stage0–2) + vår kiosk-stage.
STAGE_LIST="stage0 stage1 stage2 stage-kiosk"
